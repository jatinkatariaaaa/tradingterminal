# Supabase (Phase 3). Copy to .env.local and fill in from your Supabase project
# Settings -> API. Only the anon key is exposed to the browser; the service-role
# key must NEVER be shipped to the client and is used only by trusted server
# code (Next.js route handlers and the separate Node risk worker).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. Keep out of any NEXT_PUBLIC_* variable.
SUPABASE_SERVICE_ROLE_KEY=
