# Risk worker environment. This service is server-only and uses the service-role
# key, which BYPASSES RLS. Never expose these values to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Finnhub API key for live price quotes (forex/commodities).
FINNHUB_API_KEY=

# Tick cadence in milliseconds (how often equity/breaches are recomputed).
RISK_TICK_MS=500

# Finnhub FX/metals poll interval in milliseconds.
FINNHUB_POLL_MS=15000
